{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
      "${mod_author}"
    ],
    "contact": {
      "sources": "https://github.com/fakeneko/fakeneko_config",
      "homepage": "https://github.com/fakeneko/fakeneko_config",
      "issues": "https://github.com/fakeneko/fakeneko_config/issues"
    },
    "license": "${license}",
    "icon": "assets/${mod_id}/icon.png",
    "environment": "client",
    "entrypoints": {
      "main": [
        "cn.com.fakeneko.config.fabric.FakenekoConfigFabric"
      ],
      "client": [
        "cn.com.fakeneko.config.fabric.FakenekoConfigFabricClient"
      ],
      "modmenu": [
        "cn.com.fakeneko.config.fabric.FakenekoConfigModMenu"
      ]
    },
    "mixins": [
      "${mod_id}-common.mixins.json"
    ],
    "accessWidener": "${mod_id}.accesswidener",
    "depends": {
      "fabricloader": ">=0.13",
      "minecraft": "1.18.x",
      "java": ">=17"
    },
    "suggests": {
      "modmenu": "*"
    }
}
